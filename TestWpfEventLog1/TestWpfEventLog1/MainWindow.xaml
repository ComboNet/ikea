<Window x:Class="TestWpfEventLog1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfEventLog1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Add" Width="120" Command="{Binding AddLogCommand}"/>
            <Button Content="Read" Width="120" Command="{Binding ReadLogsCommand}"/>
            <Button Content="Clear" Width="120" Command="{Binding ClearLogsCommand}"/>
            <Button Content="Delete" Width="120" Command="{Binding DeleteEventLogCommand}"/>
        </StackPanel>
        <ListBox Grid.Row="1" ItemsSource="{Binding Items}"/>
    </Grid>
</Window>
