<UserControl x:Class="TestWpfReadExpFile1.View.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TestWpfReadExpFile1.View"
             xmlns:vm="clr-namespace:TestWpfReadExpFile1.ViewModel"
             xmlns:models ="clr-namespace:TestWpfReadExpFile1.Model"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:ViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Experiments" Width="120" Command="{Binding ExperimentsCommand}"/>
            <Button Content="Preview" Width="120" Command="{Binding PreViewCommand}"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=Experiments}" 
                      SelectedItem="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=SelectedExperiment}" AutoGenerateColumns="True" CanUserAddRows="False"/>
            <DataGrid Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=DataView}" AutoGenerateColumns="True" CanUserAddRows="False"/>
            <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=Checkboxes}" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Checked, Mode=TwoWay}" VerticalAlignment="Center" BorderThickness="0"/>
                            <TextBlock Grid.Column="1" FontSize="16" VerticalAlignment="Center">
                                <Run Text="{Binding Label}"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!--<ListBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Items}"/>-->
            <lvc:CartesianChart Grid.Row="1" Grid.Column="1" x:Name="cartesianChart" 
                                Series="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=Series}" 
                                YAxes="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=YAxes}" XAxes="{Binding XAxes}"
                                Sections="{Binding Sections}" 
                                ZoomMode="X" EasingFunction="{x:Null}" AnimationsSpeed="0"
                                Margin="0,24,0,0" HorizontalAlignment="Stretch">
                <lvc:CartesianChart.CacheMode>
                    <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False"/>
                </lvc:CartesianChart.CacheMode>
            </lvc:CartesianChart>

            <!--<lvc:CartesianChart x:Name="cartesianChart" Series="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=Series}" 
                    YAxes="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=YAxes}" 
                    XAxes="{Binding Source={x:Static models:AppData.HistoricalModel}, Path=XAxes}"
                    Sections="{Binding Sections}" ZoomMode="X" EasingFunction="{x:Null}" AnimationsSpeed="0" DrawMarginFrame="{Binding Frame}"
                    LegendPosition="{Binding LegendPosition}" LegendBackgroundPaint="{Binding LedgendBackgroundPaint}" 
                    LegendTextPaint="{Binding LegendTextPaint}" LegendTextSize="16"
                    TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}" TooltipTextPaint="{Binding TooltipTextPaint}"
                    Margin="0,24,0,0" HorizontalAlignment="Stretch">
    <lvc:CartesianChart.CacheMode>
        <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False"/>
    </lvc:CartesianChart.CacheMode>
</lvc:CartesianChart>-->
        </Grid>
    </Grid>
</UserControl>
