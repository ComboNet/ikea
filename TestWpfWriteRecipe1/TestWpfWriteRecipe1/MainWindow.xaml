<Window x:Class="TestWpfWriteRecipe1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfWriteRecipe1"
        mc:Ignorable="d"
        Title="Recipes" Height="640" Width="960" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <!--<Button Content="Test" Width="120" Command="{Binding TestCommand}"/>-->
            <Button Content="Clear" Width="120" Command="{Binding ClearCommand}"/>
            <Button Content="List" Width="120" Command="{Binding ListCommand}"/>
            <Button Content="Read" Width="120" Command="{Binding ReadCommand}"/>
            <Button Content="Add" Width="120" Command="{Binding AddCommand}"/>
            <Button Content="Edit" Width="120" Command="{Binding EditCommand}"/>
            <Button Content="Delete" Width="120" Command="{Binding DeleteCommand}"/>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipe}" AutoGenerateColumns="True"/>
        <!--<ListBox Grid.Row="1" ItemsSource="{Binding Items}"/>-->
    </Grid>
</Window>
