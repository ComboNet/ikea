<Window x:Class="TestWpfSpinImage1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfSpinImage1"
        mc:Ignorable="d"
        Title="TestWpfSpinImage1" Height="450" Width="800">
    <StackPanel Orientation="Vertical">
        <Button Content="Spin Me!" Width="150" Height="50">
            <Button.RenderTransform>
                <RotateTransform>
                </RotateTransform>
            </Button.RenderTransform>
        </Button>
        <Slider Minimum="0" Maximum="20" Value="{Binding RotationSpeed}" />
    </StackPanel>
</Window>
