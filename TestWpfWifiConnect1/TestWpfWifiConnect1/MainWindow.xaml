<Window x:Class="TestWpfWifiConnect1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfWifiConnect1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Sub ON" Command="{Binding SubOnCommand}"/>
            <Button Content="Sub OFF" Command="{Binding SubOffCommand}"/>
            <Button Content="Acid On" Command="{Binding OnCommand}"/>
            <Button Content="Acid Off" Command="{Binding OffCommand}"/>
        </StackPanel>
        <Label Grid.Row="1" Content="{Binding Message}"/>
    </Grid>
</Window>
