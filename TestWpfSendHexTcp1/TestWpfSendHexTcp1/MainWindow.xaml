<Window x:Class="TestWpfSendHexTcp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfSendHexTcp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button x:Name="button1" Content="OK" Width="120" Click="button1_Click"/>
            <Button x:Name="button2" Content="Save" Width="120" Click="button2_Click"/>
            <Button x:Name="button3" Content="App Sync" Width="120" Click="button3_Click"/>
            <Button x:Name="button4" Content="User" Width="120" Click="button4_Click"/>
            <Button x:Name="button5" Content="Recipe" Width="120" Click="button5_Click"/>
            <Button x:Name="button6" Content="Experiment" Width="120" Click="button6_Click"/>
        </StackPanel>
        <ListBox Grid.Row="1" x:Name="listBox1"/>
    </Grid>
</Window>
