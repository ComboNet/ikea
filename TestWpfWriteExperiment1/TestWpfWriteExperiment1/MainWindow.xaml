<Window x:Class="TestWpfWriteExperiment1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfWriteExperiment1"
        mc:Ignorable="d"
        Title="MainWindow" Height="640" Width="960" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Start" Width="80" Command="{Binding StartCommand}"/>
                <Button Content="Stop" Width="80" Command="{Binding StopCommand}"/>
                <Button Content="CSV" Width="80" Command="{Binding CsvCommand}"/>
                <Button Content="Alarm" Width="80" Command="{Binding AlarmCommand}"/>
                <Button Content="CheckLength" Width="80" Command="{Binding CheckLengthCommand}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Button Content="Clear" Width="80" Command="{Binding ClearCommand}"/>
                <Button Content="List" Width="80" Command="{Binding ListCommand}"/>
                <Button Content="Read" Width="80" Command="{Binding ReadCommand}"/>
                <Button Content="Add" Width="80" Command="{Binding AddCommand}"/>
                <Button Content="Delete" Width="80" Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </DockPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Experiments}" SelectedItem="{Binding SelectedExperiment}" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single"/>
        <GridSplitter Grid.Row="2" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <DataGrid Grid.Row="3" ItemsSource="{Binding DataView}" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single"/>
        <!--<ListBox Grid.Row="2" ItemsSource="{Binding Items}"/>-->
    </Grid>
</Window>
