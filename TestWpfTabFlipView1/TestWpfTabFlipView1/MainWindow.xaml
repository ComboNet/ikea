<mah:MetroWindow x:Class="TestWpfTabFlipView1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfTabFlipView1"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Tab FlipView Example" Height="450" Width="800">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedIndex}">
            <TabItem Header="One"/>
            <TabItem Header="Two"/>
        </TabControl>
        <mah:FlipView Grid.Row="1" ItemsSource="{Binding ItemsSource}" SelectedIndex="{Binding SelectedIndex}" 
                      MouseHoverBorderEnabled="False" IsNavigationEnabled="False" IsBannerEnabled="False">
            <mah:FlipView.ItemTemplate>
                <DataTemplate>
                    <Frame Content="{Binding}" NavigationUIVisibility="Hidden"/>
                </DataTemplate>
            </mah:FlipView.ItemTemplate>
        </mah:FlipView>
    </Grid>
</mah:MetroWindow>
