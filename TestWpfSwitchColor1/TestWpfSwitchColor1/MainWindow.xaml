<Window x:Class="TestWpfSwitchColor1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfSwitchColor1"
        mc:Ignorable="d"
        Title="TestWpfSwitchColor1" Height="450" Width="800">
    <Window.DataContext>
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="Red Blink" Width="120" Command="{Binding RedBlinkCommand}"/>
            <Button Content="Green" Width="120" Command="{Binding GreenCommand}"/>
            <Button Content="Yellow" Width="120" Command="{Binding YellowCommand}"/>
            <Button Content="Null" Width="120" Command="{Binding NullCommand}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush>
                    <GradientStop Color="Red" Offset="0.0" />
                    <GradientStop x:Name="AnimatedStop" Color="Blue" Offset="0.5" />
                    <GradientStop Color="Green" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="AnimatedStop" Storyboard.TargetProperty="Color" To="Yellow" 
                                            Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>

