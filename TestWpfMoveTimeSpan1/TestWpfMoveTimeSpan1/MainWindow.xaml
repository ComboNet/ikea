<Window x:Class="TestWpfMoveTimeSpan1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfMoveTimeSpan1"
        mc:Ignorable="d"
        Title="MainWindow" Height="460" Width="800" Loaded="Window_Loaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" x:Name="button1" Content="OK" Width="120" HorizontalAlignment="Left" Click="button1_Click"/>
        <TextBox  Grid.Row="1" x:Name="textBox1"/>
        <ListBox Grid.Row="2" x:Name="listBox1"/>
        <Line x:Name="line1" X1="10" Y1="0" X2="10" Y2="460" Panel.ZIndex="1"/>
    </Grid>
    
</Window>
